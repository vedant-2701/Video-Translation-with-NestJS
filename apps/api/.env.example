# ═══════════════════════════════════════════════════════════════════════════════
# Video Translation NestJS API — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# 
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control.

# ─────────────────────────────────────────────────────────────────────────────
# 🗄️  DATABASE (PostgreSQL)
# ─────────────────────────────────────────────────────────────────────────────

# Full PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/video_translation

# Docker Compose credentials (used in docker-compose.yml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=video_translation

# ─────────────────────────────────────────────────────────────────────────────
# 🔴 REDIS (Cache & Job Queue)
# ─────────────────────────────────────────────────────────────────────────────

REDIS_HOST=localhost
REDIS_PORT=6379

# Optional: Redis password (leave blank if not used)
# REDIS_PASSWORD=yourpassword

# ─────────────────────────────────────────────────────────────────────────────
# 💾 STORAGE (S3, MinIO, or Local)
# ─────────────────────────────────────────────────────────────────────────────

# Storage driver: 'local', 's3', or 'minio'
STORAGE_DRIVER=s3

# ──── AWS S3 ──────────────────────────────────────────────────────────────────
# Use these if STORAGE_DRIVER=s3

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKAKAKAFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJylqXutnFEMI/K7WDCNT/bPxRfiCYEXAMPLEKEY
AWS_S3_BUCKET=video-translation-bucket

# ──── MinIO ────────────────────────────────────────────────────────────────────
# Use these if STORAGE_DRIVER=minio

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=video-translation
MINIO_USE_SSL=false  # Set to 'true' for HTTPS

# ──── Local Storage ─────────────────────────────────────────────────────────────
# Use these if STORAGE_DRIVER=local

STORAGE_LOCAL_PATH=./storage
STORAGE_OUTPUT_PATH=./storage/outputs

# ─────────────────────────────────────────────────────────────────────────────
# 🚀 API SERVER
# ─────────────────────────────────────────────────────────────────────────────

PORT=3000
NODE_ENV=development

# CORS allowed origin (frontend URL)
CORS_ORIGIN=http://localhost:3001

# Max file upload size in MB
MAX_FILE_SIZE_MB=500

# Job cleanup: Retain completed/failed jobs for N days (0 = never delete)
JOB_RETENTION_DAYS=30

# ─────────────────────────────────────────────────────────────────────────────
# 🤖 AI APIs
# ─────────────────────────────────────────────────────────────────────────────

# Sarvam AI (REQUIRED for translation)
# Get your key from: https://console.sarvam.ai
SARVAM_API_KEY=sk_your_sarvam_api_key_here

# Voicebox (Optional TTS alternative)
# Leave blank to use Sarvam Bulbul TTS
VOICEBOX_URL=https://your-voicebox-endpoint.ngrok-free.dev
VOICEBOX_ENGINE=chatterbox
VOICEBOX_FALLBACK_TO_BULBUL=false

# ─────────────────────────────────────────────────────────────────────────────
# 🔐 WORKER (Authentication & Communication)
# ─────────────────────────────────────────────────────────────────────────────

# Secret header for worker authentication
# Workers must send: X-Worker-Secret: {this-value}
# Share this secret only with trusted worker instances
WORKER_SECRET=your-worker-secret-change-me-in-production

# Worker health check timeout (seconds)
WORKER_HEALTH_CHECK_TIMEOUT=30

# ─────────────────────────────────────────────────────────────────────────────
# 📝 LOGGING (Pino)
# ─────────────────────────────────────────────────────────────────────────────

# Log level: 'debug', 'info', 'warn', 'error', 'fatal'
LOG_LEVEL=debug

# Log transport: 'console' or 'file'
LOG_TRANSPORT=console

# Log file path (if LOG_TRANSPORT=file)
# LOG_FILE_PATH=./logs/app.log

# ═══════════════════════════════════════════════════════════════════════════════
# FRONTEND (.env.local in apps/web)
# ═══════════════════════════════════════════════════════════════════════════════
# 
# NEXT_PUBLIC_API_URL=http://localhost:3000/api
#

{
  "CORSRules": [
    {
      "AllowedHeaders": [
        "*"
      ],
      "AllowedMethods": [
        "GET",
        "PUT",
        "POST",
        "DELETE",
        "HEAD"
      ],
      "AllowedOrigins": [
        "http://localhost:3001",
        "http://localhost:3000",
        "http://127.0.0.1:3001",
        "http://127.0.0.1:3000"
      ],
      "ExposeHeaders": [
        "ETag",
        "x-amz-version-id",
        "x-amz-checksum-crc32"
      ],
      "MaxAgeSeconds": 3000
    }
  ]
}
